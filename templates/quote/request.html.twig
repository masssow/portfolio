{# templates/quote/request.html.twig #}
{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'quote.seo.titleTab'|trans }}{% endblock %}
{% block meta_description %}{{ 'quote.seo.metaDesc'|trans }}{% endblock %}

{% block body %}
<section class="contact_area section_gap">
  <div class="container">

    <div class="row justify-content-center mb-5">
      <div class="col-lg-8 text-center">
        <h1 class="mb-2">{{ 'quote.seo.firstTitle'|trans }}</h1>
        <p class="text-muted">{{ 'quote.subtitle'|trans }}</p>
      </div>
    </div>

    {% for message in app.flashes('warning') %}
      <div class="alert alert-warning mb-3">{{ message|raw }}</div>
    {% endfor %}

    <div class="row">

      <!-- Colonne gauche : infos contact -->
      <div class="col-lg-4 mb-4 mb-lg-0">
        <div class="contact_info" style="background:#f9f9ff;border-radius:12px;padding:32px 28px;">
          <h2 class="mb-4">{{ 'quote.form.titleContact'|trans }}</h2>

          <div class="info_item">
            <i class="lnr lnr-home"></i>
            <h6>{{ 'quote.form.country'|trans }}</h6>
            <p>{{ 'quote.form.modeCom'|trans }}</p>
          </div>

          <div class="info_item mt-3">
            <i class="lnr lnr-phone-handset"></i>
            <h6><a href="tel:+33666117428">(+33) 6 66 11 74 28</a></h6>
            <p>{{ 'home.badge.small'|trans }}</p>
          </div>

          <div class="info_item mt-3">
            <i class="lnr lnr-envelope"></i>
            <h6 style="word-break:break-all;"><a href="mailto:contact.massgrafik@gmail.com">contact.massgrafik@gmail.com</a></h6>
          </div>
        </div>
      </div>

      <!-- Colonne droite : formulaire -->
      <div class="col-lg-8">
        <h2 class="mb-4">{{ 'quote.form.titleFormContact'|trans }}</h2>

        {{ form_errors(form) }}

        {{ form_start(form, {
          action: path('app_quote', {'_locale': app.request.locale}),
          method: 'POST',
          attr: {
            class: 'contact_form',
            id: 'quoteForm'
          }
        }) }}

          <div class="row">
            <div class="col-md-6">
              <div class="form-group">
                {{ form_widget(form.name, { attr: { class: 'form-control', placeholder: 'quote.form.name'|trans } }) }}
                {{ form_errors(form.name) }}
              </div>
              <div class="form-group">
                {{ form_widget(form.email, { attr: { class: 'form-control', placeholder: 'quote.form.email'|trans } }) }}
                {{ form_errors(form.email) }}
              </div>
              <div class="form-group">
                <div class="phone-prefix-group input-group">
                  <div class="input-group-prepend">
                    <select id="phonePrefixSelect" class="form-control phone-prefix-select" aria-label="{{ 'quote.form.phone_prefix'|trans }}">
                      <option value="+33"  data-flag="🇫🇷">🇫🇷 +33</option>
                      <option value="+34"  data-flag="🇪🇸">🇪🇸 +34</option>
                      <option value="+221" data-flag="🇸🇳">🇸🇳 +221</option>
                      <option value="+32"  data-flag="🇧🇪">🇧🇪 +32</option>
                      <option value="+41"  data-flag="🇨🇭">🇨🇭 +41</option>
                      <option value="+49"  data-flag="🇩🇪">🇩🇪 +49</option>
                      <option value="+44"  data-flag="🇬🇧">🇬🇧 +44</option>
                      <option value="+1"   data-flag="🇺🇸">🇺🇸 +1</option>
                      <option value="+1"   data-flag="🇨🇦">🇨🇦 +1</option>
                      <option value="+212" data-flag="🇲🇦">🇲🇦 +212</option>
                      <option value="+225" data-flag="🇨🇮">🇨🇮 +225</option>
                      <option value="+237" data-flag="🇨🇲">🇨🇲 +237</option>
                      <option value="+223" data-flag="🇲🇱">🇲🇱 +223</option>
                      <option value="+224" data-flag="🇬🇳">🇬🇳 +224</option>
                      <option value="+213" data-flag="🇩🇿">🇩🇿 +213</option>
                      <option value="+216" data-flag="🇹🇳">🇹🇳 +216</option>
                      <option value="+222" data-flag="🇲🇷">🇲🇷 +222</option>
                      <option value="+351" data-flag="🇵🇹">🇵🇹 +351</option>
                      <option value="+39"  data-flag="🇮🇹">🇮🇹 +39</option>
                      <option value="+31"  data-flag="🇳🇱">🇳🇱 +31</option>
                      <option value="+52"  data-flag="🇲🇽">🇲🇽 +52</option>
                      <option value="+55"  data-flag="🇧🇷">🇧🇷 +55</option>
                    </select>
                  </div>
                  {{ form_widget(form.phone, { attr: { class: 'form-control', placeholder: 'quote.form.phone'|trans, id: 'phoneNumber' } }) }}
                </div>
                {{ form_errors(form.phone) }}
              </div>
              <div class="form-group">
                {{ form_widget(form.company, { attr: { class: 'form-control', placeholder: 'quote.form.company'|trans } }) }}
                {{ form_errors(form.company) }}
              </div>
            </div>

            <div class="col-md-6">
              <div class="form-group">
                <label class="form-label" for="{{ form.pack.vars.id }}">{{ 'quote.form.pack'|trans }}</label>
                {{ form_widget(form.pack, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.pack) }}
              </div>
              <div class="form-group">
                {{ form_widget(form.message, { attr: { class: 'form-control', rows: 6, placeholder: 'quote.form.message'|trans } }) }}
                {{ form_errors(form.message) }}
              </div>
            </div>
          </div>

          {{ form_widget(form.render_ts) }}

          {# Honeypot invisible #}
          <input type="text"
                 name="{{ form.vars.name }}[{{ honeypot_name }}]"
                 value=""
                 autocomplete="off"
                 tabindex="-1"
                 aria-hidden="true"
                 style="position:absolute;left:-9999px;width:0;height:0;opacity:0;pointer-events:none" />

          {{ form_widget(form._token) }}

          <div class="text-right mt-3">
            <button type="submit" class="primary_btn">
              <span>{{ 'quote.form.submit'|trans }}</span>
            </button>
          </div>

        {{ form_end(form, { render_rest: false }) }}
      </div>

    </div>

    <div id="mapBox" class="mapBox"
         data-lat="48.8566"
         data-lon="2.3522"
         data-zoom="11"
         data-info="Contact MassGrafik — France."
         data-mlat="48.8566"
         data-mlon="2.3522">
    </div>

  </div>
</section>

{% block javascripts %}
{{ parent() }}
<script>
(function () {
  var form   = document.getElementById('quoteForm');
  var select = document.getElementById('phonePrefixSelect');
  var phone  = document.getElementById('phoneNumber');
  if (!form || !select || !phone) return;
  form.addEventListener('submit', function () {
    var raw = phone.value.trim().replace(/^\+\d+\s*/, '');
    if (raw && !phone.value.trim().startsWith('+')) {
      phone.value = select.value + ' ' + raw;
    }
  });
})();
</script>
{% endblock %}

{% endblock %}
