{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'home.seo.titleTab'|trans }}{% endblock %}
{% block meta_description %}{{ 'home.seo.metaDesc'|trans }}{% endblock %}

{% block body %}

{# ===== HERO ===== #}
<section class="home_banner_area">
  <div class="banner_inner">
    <div class="container">
      <div class="row align-items-center">

        <div class="col-lg-6">
          <div class="banner_content">
            <h3 class="hero-salutation">{{ 'home.hero.salutation'|trans }}</h3>
            <h2>{{ 'home.hero.h1'|trans }}</h2>
            <h5>{{ 'home.hero.subtitle'|trans }}</h5>
            <a class="primary_btn mt-3"
               href="{{ path('app_quote', {'_locale': app.request.locale}) }}">
              <span>{{ 'cta.devis'|trans }}</span>
            </a>
            <a class="primary_btn tr-bg mt-3 ml-2"
               href="{{ path('app_services', {'_locale': app.request.locale}) }}">
              <span>{{ 'cta.discover'|trans }}</span>
            </a>
            <p class="mt-3 mb-0 hero-proofs">{{ 'home.hero.proofs'|trans }}</p>
          </div>
        </div>

        {# REMPLACER : photo équipe / personne au travail / mockup écran — 600×500 px #}
        <div class="col-lg-5 offset-lg-1 mt-4 mt-lg-0">
          <div class="img-ph img-ph--hero">
            <img src="{{ asset('build/images/pexels-tranmau.jpg') }}"
                 alt="MassGrafik — solutions digitales sur mesure"
                 class="img-ph__img"
                 onerror="this.remove()">
            <div class="img-ph__fallback">
              <i class="fa-solid fa-image fa-2x"></i>
              <span>Photo : équipe ou workspace<br><small>600 × 500 px</small></span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

{# ===== MIRROR — Vous vous reconnaissez ? ===== #}
<section class="about_area section_gap">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <div class="main_title">
          <h2>{{ 'home.mirror.title'|trans }}</h2>
          <p>{{ 'home.mirror.subtitle'|trans }}</p>
        </div>
      </div>
    </div>
    <div class="row">
      {% for i in 1..4 %}
        <div class="col-lg-6 mb-4">
          <div class="feature_item feature_item--mirror">
            <div class="mirror-num">{{ i }}</div>
            <h4>{{ ('home.mirror.items.' ~ i ~ '.title')|trans }}</h4>
            <p>{{ ('home.mirror.items.' ~ i ~ '.text')|trans }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ===== SOLUTIONS — Ce que MassGrafik peut faire ===== #}
<section class="features_area section_gap bg-light-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <div class="main_title">
          <h2>{{ 'home.solutions.title'|trans }}</h2>
          <p>{{ 'home.solutions.subtitle'|trans }}</p>
        </div>
      </div>
    </div>
    <div class="row feature_inner">
      {% set solutions = [
        { icon: 'fa-globe',              color: 'teal',   slug: 'sites-web',       label: 'home.solutions.web.title',        desc: 'home.solutions.web.desc' },
        { icon: 'fa-cart-shopping',      color: 'purple', slug: 'e-commerce',      label: 'home.solutions.ecom.title',       desc: 'home.solutions.ecom.desc' },
        { icon: 'fa-screwdriver-wrench', color: 'coral',  slug: 'outils-gestion',  label: 'home.solutions.tools.title',      desc: 'home.solutions.tools.desc' },
        { icon: 'fa-bolt',               color: 'gold',   slug: 'automatisations', label: 'home.solutions.auto.title',       desc: 'home.solutions.auto.desc' },
        { icon: 'fa-calendar-check',     color: 'green',  slug: 'reservations',    label: 'home.solutions.booking.title',    desc: 'home.solutions.booking.desc' },
        { icon: 'fa-shield-halved',      color: 'blue',   slug: 'maintenance',     label: 'home.solutions.operations.title', desc: 'home.solutions.operations.desc' }
      ] %}
      {% for s in solutions %}
        <div class="col-lg-4 col-md-6">
          <a href="{{ path('app_service_detail', {'_locale': app.request.locale, 'slug': s.slug}) }}"
             class="feature_item text-center feature_item--{{ s.color }} feature_item--link">
            <div class="pack-icon pack-icon--{{ s.color }} mx-auto">
              <i class="fa-solid {{ s.icon }}"></i>
            </div>
            <h4>{{ s.label|trans }}</h4>
            <p>{{ s.desc|trans }}</p>
          </a>
        </div>
      {% endfor %}
    </div>
    <div class="row justify-content-center mt-4">
      <div class="col-auto">
        <a class="primary_btn"
           href="{{ path('app_services', {'_locale': app.request.locale}) }}">
          <span>{{ 'cta.discover'|trans }}</span>
        </a>
      </div>
    </div>
  </div>
</section>

{# ===== MÉTHODE ===== #}
<section class="about_area section_gap">
  <div class="container">
    <div class="row align-items-center">

      {# REMPLACER : photo réunion / brainstorming / tableau blanc — 520×600 px #}
      <div class="col-lg-5 mb-4 mb-lg-0">
        <div class="img-ph img-ph--method">
          <img src="{{ asset('build/images/img/services/service3.png') }}"
               alt="Notre méthode de travail"
               class="img-ph__img"
               onerror="this.remove()">
          <div class="img-ph__fallback">
            <i class="fa-solid fa-image fa-2x"></i>
            <span>Photo : collaboration / réunion<br><small>520 × 600 px</small></span>
          </div>
        </div>
      </div>

      <div class="col-lg-6 offset-lg-1">
        <div class="main_title text-left">
          <h2>{{ 'home.method.title'|trans }}</h2>
        </div>
        {% for i in 1..3 %}
          <div class="method-step">
            <span class="method-num">{{ ('home.method.steps.' ~ i ~ '.num')|trans }}</span>
            <h4>{{ ('home.method.steps.' ~ i ~ '.title')|trans }}</h4>
            <p>{{ ('home.method.steps.' ~ i ~ '.desc')|trans }}</p>
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{# ===== CONTACT INFO + CTA CENTRAL ===== #}
<section class="brand_area section_gap_bottom">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <div class="main_title">
          <h2>{{ 'home.cta_center.title'|trans }}</h2>
          <p>{{ 'home.cta_center.subtitle'|trans }}</p>
        </div>
        <a class="primary_btn"
           href="{{ path('app_quote', {'_locale': app.request.locale}) }}">
          <span>{{ 'home.cta_center.button'|trans }}</span>
        </a>
        <p class="mt-3 text-muted small">{{ 'home.cta_center.proof'|trans }}</p>
      </div>
    </div>

    <div class="row justify-content-center align-items-center mt-5">

      {# REMPLACER : portrait du fondateur / photo professionnelle — 280×340 px #}
      <div class="col-lg-3 col-md-4 mb-4 mb-md-0 text-center">
        <div class="img-ph img-ph--portrait">
          <img src="{{ asset('build/images/portrait-massgrafik.jpg') }}"
               alt="MassGrafik — fondateur"
               class="img-ph__img"
               onerror="this.remove()">
          <div class="img-ph__fallback">
            <i class="fa-solid fa-user-tie fa-2x"></i>
            <span>Portrait<br><small>280 × 340 px</small></span>
          </div>
        </div>
      </div>

      <div class="col-lg-5 col-md-7">
        <div class="client-info">
          <div class="call-now d-flex">
            <div><span class="fa fa-phone"></span></div>
            <div class="ml-15">
              <p>{{ 'contact.direct'|trans }}</p>
              <h3>(+33) 6 66 11 74 28</h3>
            </div>
          </div>
          <hr>
          <p class="mb-1"><strong>{{ 'home.zones.title'|trans }}</strong> {{ 'home.zones.list'|trans }}</p>
          <p class="mb-0"><strong>Email</strong> : contact.massgrafik@gmail.com</p>
        </div>
      </div>

    </div>
  </div>
</section>

{# ===== OFFRES ===== #}
<section class="mg-offers section_gap" id="offres">
  <div class="container">

    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <div class="main_title">
          <span class="main_title__eyebrow">{{ 'offers_cards.header.eyebrow'|trans }}</span>
          <h2>{{ 'offers_cards.header.title'|trans }}</h2>
          <p>{{ 'offers_cards.header.subtitle'|trans }}</p>
        </div>
      </div>
    </div>

    <div class="row justify-content-center mg-offers__grid">

      {# ── Starter ── #}
      <div class="col-lg-4 col-md-6">
        <article class="mg-offer-card" aria-label="{{ 'offers_cards.starter.name'|trans }}">
          <div class="mg-offer-card__top">
            <span class="mg-offer-card__badge mg-offer-card__badge--teal">
              {{ 'offers_cards.starter.badge'|trans }}
            </span>
            <h3 class="mg-offer-card__name">{{ 'offers_cards.starter.name'|trans }}</h3>
            <p class="mg-offer-card__desc">{{ 'offers_cards.starter.description'|trans }}</p>
          </div>
          <div class="mg-offer-card__pricing">
            <div class="mg-offer-card__price">
              {{ 'offers_cards.starter.price'|trans }} € <span>HT</span>
            </div>
            <div class="mg-offer-card__market">
              {{ 'offers_cards.market_label'|trans }} <s>{{ 'offers_cards.starter.market'|trans }}</s>
            </div>
          </div>
          <ul class="mg-offer-card__includes">
            {% for i in 1..6 %}
              <li class="mg-offer-card__includes-item">
                <span class="mg-offer-card__check" aria-hidden="true">✓</span>
                {{ ('offers_cards.starter.includes.' ~ i)|trans }}
              </li>
            {% endfor %}
          </ul>
          <div class="mg-offer-card__footer">
            <a class="mg-offer-card__cta"
               href="{{ path('app_quote', {'_locale': app.request.locale, 'pack': 'starter'}) }}"
               aria-label="{{ 'offers_cards.cta_label'|trans }} — {{ 'offers_cards.starter.name'|trans }}">
              {{ 'offers_cards.cta_label'|trans }}
            </a>
          </div>
        </article>
      </div>

      {# ── Pro PME (featured) ── #}
      <div class="col-lg-4 col-md-6">
        <article class="mg-offer-card mg-offer-card--featured" aria-label="{{ 'offers_cards.pro.name'|trans }}">
          <div class="mg-offer-card__top">
            <span class="mg-offer-card__badge mg-offer-card__badge--purple">
              {{ 'offers_cards.pro.badge'|trans }}
            </span>
            <h3 class="mg-offer-card__name">{{ 'offers_cards.pro.name'|trans }}</h3>
            <p class="mg-offer-card__desc">{{ 'offers_cards.pro.description'|trans }}</p>
          </div>
          <div class="mg-offer-card__pricing">
            <div class="mg-offer-card__price">
              {{ 'offers_cards.pro.price'|trans }} € <span>HT</span>
            </div>
            <div class="mg-offer-card__market">
              {{ 'offers_cards.market_label'|trans }} <s>{{ 'offers_cards.pro.market'|trans }}</s>
            </div>
          </div>
          <ul class="mg-offer-card__includes">
            {% for i in 1..6 %}
              <li class="mg-offer-card__includes-item">
                <span class="mg-offer-card__check" aria-hidden="true">✓</span>
                {{ ('offers_cards.pro.includes.' ~ i)|trans }}
              </li>
            {% endfor %}
          </ul>
          <div class="mg-offer-card__footer">
            <a class="mg-offer-card__cta mg-offer-card__cta--featured"
               href="{{ path('app_quote', {'_locale': app.request.locale, 'pack': 'pro'}) }}"
               aria-label="{{ 'offers_cards.cta_label'|trans }} — {{ 'offers_cards.pro.name'|trans }}">
              {{ 'offers_cards.cta_label'|trans }}
            </a>
          </div>
        </article>
      </div>

      {# ── Business Tool ── #}
      <div class="col-lg-4 col-md-6">
        <article class="mg-offer-card" aria-label="{{ 'offers_cards.business.name'|trans }}">
          <div class="mg-offer-card__top">
            <span class="mg-offer-card__badge mg-offer-card__badge--coral">
              {{ 'offers_cards.business.badge'|trans }}
            </span>
            <h3 class="mg-offer-card__name">{{ 'offers_cards.business.name'|trans }}</h3>
            <p class="mg-offer-card__desc">{{ 'offers_cards.business.description'|trans }}</p>
          </div>
          <div class="mg-offer-card__pricing">
            <div class="mg-offer-card__price">
              {{ 'offers_cards.business.price'|trans }} € <span>HT</span>
            </div>
            <div class="mg-offer-card__market">
              {{ 'offers_cards.market_label'|trans }} <s>{{ 'offers_cards.business.market'|trans }}</s>
            </div>
          </div>
          <ul class="mg-offer-card__includes">
            {% for i in 1..6 %}
              <li class="mg-offer-card__includes-item">
                <span class="mg-offer-card__check" aria-hidden="true">✓</span>
                {{ ('offers_cards.business.includes.' ~ i)|trans }}
              </li>
            {% endfor %}
          </ul>
          <div class="mg-offer-card__footer">
            <a class="mg-offer-card__cta"
               href="{{ path('app_quote', {'_locale': app.request.locale, 'pack': 'business'}) }}"
               aria-label="{{ 'offers_cards.cta_label'|trans }} — {{ 'offers_cards.business.name'|trans }}">
              {{ 'offers_cards.cta_label'|trans }}
            </a>
          </div>
        </article>
      </div>

    </div>

    <div class="row justify-content-center mt-4">
      <div class="col-auto text-center">
        <a class="primary_btn tr-bg"
           href="{{ path('app_tarifs', {'_locale': app.request.locale}) }}">
          <span>Voir le détail des tarifs →</span>
        </a>
      </div>
    </div>

  </div>
</section>


{# ===== CTA FINAL ===== #}
<section class="cta-final-section">
  <div class="container">
    <div class="main_title">
      <h2>{{ 'cta.talk'|trans }}</h2>
    </div>
    <a class="primary_btn"
       href="{{ path('app_quote', {'_locale': app.request.locale}) }}">
      <span>{{ 'cta.devis'|trans }}</span>
    </a>
  </div>
</section>

{% endblock %}
