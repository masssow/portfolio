{% extends 'base.html.twig' %}

{% block title %}{{ 'home.seo.titleTab'|trans }}{% endblock %}

{% block body %}
<!--================ Start Home Banner Area =================-->
<section class="home_banner_area">
  <div class="banner_inner">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7">
          <div class="banner_content">
            <h3 class="hero-salutation">{{ 'home.hero.salutation'|trans }}</h3>
            <h2>{{ 'home.hero.h1'|trans }}</h2>
            <h5>{{ 'home.hero.subtitle'|trans }}</h5>

            <a class="primary_btn mt-3"
               href="{{ path('app_quote', {'_locale': app.request.locale}) }}">
              <span>{{ 'cta.devis'|trans }}</span>
            </a>

            <p class="mt-3 mb-0">{{ 'home.hero.proofs'|trans }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>



<!--============ End Home Banner Area =================-->

<!--================ Start About/Why Area =================-->

<section class="about_area section_gap">
  <div class="container">
    <div class="row justify-content-start align-items-center">
      <div class="col-lg-6">
        <div class="main_title text-left">
          <h2>Pourquoi MassGrafik ?</h2>
          <p>Méthode claire, livrables concrets et résultats mesurables.</p>

          <ul>
            <li>Audit express (30 min)</li>
            <li>Plan d’action priorisé</li>
            <li>Design orienté conversion</li>
            <li>Sites rapides, mobiles et évolutifs</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!--================ End About/Why Area =================-->

<!--================ Start Brand/Trust Area =================-->
<section class="brand_area section_gap_bottom">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6">
        <div class="row">
          <div class="col-lg-4 col-md-4 col-sm-6">
            <div class="single-brand-item d-table">
              <div class="d-table-cell text-center">
                <img src="{{ asset('build/images/img/brands/logo1.png') }}" alt="Artisanat">
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-4 col-sm-6">
            <div class="single-brand-item d-table">
              <div class="d-table-cell text-center">
                <img src="{{ asset('build/images/img/brands/dsthermologo.jpg') }}" alt="Restauration">
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-4 col-sm-6">
            <div class="single-brand-item d-table">
              <div class="d-table-cell text-center">
                <img src="{{ asset('build/img/brands/logo3.png') }}" alt="Services">
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-4 col-sm-6">
            <div class="single-brand-item d-table">
              <div class="d-table-cell text-center">
                <img src="{{ asset('build/images/img/brands/logo4.png') }}" alt="Associations">
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="offset-lg-2 col-lg-4 col-md-6">
        <div class="client-info">
          <div class="d-flex mb-50">
            <span class="lage">{{ 'home.badge.large'|trans }}</span>
            <span class="smll"> {{ 'home.badge.small'|trans }}</span>
          </div>
          <div class="call-now d-flex">
            <div>
              <span class="fa fa-phone"></span>
            </div>
            <div class="ml-15">
              <p>{{ 'contact.direct'|trans }}</p>
              <h3>(+33) 6 66 11 74 28</h3>
            </div>
          </div>
          <hr>
          <p class="mb-1"><strong>{{ 'home.zones.title'|trans }}</strong> {{ 'home.zones.list'|trans }}</p>
          <p class="mb-0"><strong>Email</strong> : contact.massgrafik@gmail.com</p>
        </div>
      </div>
    </div>
  </div>
</section>
<!--================ End Brand/Trust Area =================-->

<!--================ Start Features Area (Nos offres) =================-->

<section class="about_area section_gap">
  <div class="container">
    <div class="row align-items-center">

      <div class="col-lg-6 mb-4 mb-lg-0">
        <img class="img-fluid"
             src="{{ asset('build/images/massgrafik-commerce-composite.png') }}"
             alt="MassGrafik Commerce">
      </div>

      <div class="col-lg-5 offset-lg-1">
        <div class="main_title text-left">
          <h2>{{ 'home.commerce.title'|trans }}</h2>
          <p>{{ 'home.commerce.desc'|trans }}</p>

          <ul>
            <li>{{ 'home.commerce.items.1'|trans }}</li>
            <li>{{ 'home.commerce.items.2'|trans }}</li>
            <li>{{ 'home.commerce.items.3'|trans }}</li>
            <li>{{ 'home.commerce.items.4'|trans }}</li>
          </ul>

          <a class="primary_btn mt-3"
             href="{{ path('app_quote', {'_locale': app.request.locale, 'pack': 'ecom'}) }}">
            <span>{{ 'home.commerce.cta'|trans }}</span>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>



<!--================ End Features Area (Nos offres) =================-->
<section class="features_area section_gap" id="packs">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <div class="main_title">
          <h2>{{ 'home.packs.title'|trans }}</h2>
          <p>{{ 'home.packs.intro'|trans }}</p>
        </div>
      </div>
    </div>

    <div class="row feature_inner">
      {% for key in ['local','ecom','com','maint','social'] %}
        <div class="col-lg-4 col-md-6">
          <div class="feature_item">
            <h4>{{ ('packs.' ~ key ~ '.title')|trans }}</h4>
            <p>{{ ('packs.' ~ key ~ '.desc')|trans }}</p>
            <a class="primary_btn tr-bg"
               href="{{ path('app_quote', {'_locale': app.request.locale, 'pack': key}) }}">
              <span>{{ ('packs.' ~ key ~ '.cta')|trans }}</span>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section_gap text-center">
  <a class="primary_btn"
     href="{{ path('app_quote', {'_locale': app.request.locale}) }}">
    <span>{{ 'cta.talk'|trans }}</span>
  </a>
</section>


{% endblock %}
