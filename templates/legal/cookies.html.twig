{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}
{% block title %}{{ 'legal.cookies.seo.titleTab'|trans }}{% endblock %}

{% block body %}
<section class="about_area section_gap">
  <div class="container" style="max-width:780px;">
    <h1 class="mb-2">{{ 'legal.cookies.title'|trans }}</h1>
    <p class="text-muted mb-4">{{ 'legal.cookies.intro'|trans }}</p>

    <h3 class="mt-4">{{ 'legal.cookies.commitment.title'|trans }}</h3>
    <p class="alert" style="background:#eef6ff;border-left:4px solid #6192be;padding:16px 20px;border-radius:6px;">
      {{ 'legal.cookies.commitment.value'|trans }}
    </p>

    <h3 class="mt-4">{{ 'legal.cookies.what.title'|trans }}</h3>
    <p>{{ 'legal.cookies.what.value'|trans }}</p>

    <h3 class="mt-4">{{ 'legal.cookies.types.title'|trans }}</h3>

    <h5 class="mt-3">{{ 'legal.cookies.types.necessary_title'|trans }}</h5>
    <ul>
      <li class="mb-1">{{ 'legal.cookies.types.necessary_1'|trans }}</li>
      <li class="mb-1">{{ 'legal.cookies.types.necessary_2'|trans }}</li>
    </ul>

    <h5 class="mt-3">{{ 'legal.cookies.types.analytics_title'|trans }}</h5>
    <ul>
      <li class="mb-1">{{ 'legal.cookies.types.analytics_1'|trans }}</li>
    </ul>

    <h5 class="mt-3">{{ 'legal.cookies.types.social_title'|trans }}</h5>
    <ul>
      <li class="mb-1">{{ 'legal.cookies.types.social_1'|trans }}</li>
    </ul>

    <h3 class="mt-4">{{ 'legal.cookies.notdeposited.title'|trans }}</h3>
    <ul>
      {% for i in 1..3 %}
        <li class="mb-1"><strong>{{ ('legal.cookies.notdeposited.' ~ i)|trans }}</strong></li>
      {% endfor %}
    </ul>

    <h3 class="mt-4">{{ 'legal.cookies.manage.title'|trans }}</h3>
    <p>{{ 'legal.cookies.manage.banner'|trans }}</p>
    <p>{{ 'legal.cookies.manage.browser'|trans }}</p>
    <ul>
      {% for i in 1..4 %}
        <li class="mb-1">{{ ('legal.cookies.manage.browser_' ~ i)|trans }}</li>
      {% endfor %}
    </ul>
    <p class="text-muted small">{{ 'legal.cookies.manage.note'|trans }}</p>

    <h3 class="mt-4">{{ 'legal.cookies.contact.title'|trans }}</h3>
    <p>{{ 'legal.cookies.contact.value'|trans }}</p>

    <p class="mt-5 text-muted small">{{ 'legal.lastUpdate'|trans({'%date%': "now"|date('d/m/Y')}) }}</p>
  </div>
</section>
{% endblock %}
