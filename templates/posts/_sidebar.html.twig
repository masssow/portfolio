
<div class="col-lg-4">
  <div class="blog_right_sidebar">

    {# ── Bio auteur ── #}
    <aside class="single_sidebar_widget author_widget">
      <h4 class="mb-0">Samba SOW</h4>
      <p class="text-muted small mb-2">Fondateur — MassGrafik</p>
      <p>Développeur web indépendant basé à Paris, Samba accompagne artisans, commerçants et petites structures dans leur transformation digitale. Spécialisé en sites professionnels, outils de gestion sur mesure et automatisations métier, il intervient en France (IDF), en Espagne et au Sénégal.</p>
      <div class="social_icon mt-2">
        {% set _shareUrl = app.request.uri|escape('url') %}
        {% set _shareTitle = (post.title is defined ? post.title : 'Ressources MassGrafik')|escape('url') %}
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ _shareUrl }}"
           target="_blank" rel="noopener" aria-label="Partager sur Facebook">
          <i class="fa-brands fa-facebook-f"></i>
        </a>
        <a href="https://twitter.com/intent/tweet?url={{ _shareUrl }}&text={{ _shareTitle }}"
           target="_blank" rel="noopener" aria-label="Partager sur X">
          <i class="fa-brands fa-x-twitter"></i>
        </a>
        <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ _shareUrl }}&title={{ _shareTitle }}"
           target="_blank" rel="noopener" aria-label="Partager sur LinkedIn">
          <i class="fa-brands fa-linkedin"></i>
        </a>
        <a href="https://api.whatsapp.com/send?text={{ _shareTitle }}%20{{ _shareUrl }}"
           target="_blank" rel="noopener" aria-label="Partager sur WhatsApp">
          <i class="fa-brands fa-whatsapp"></i>
        </a>
      </div>
      <div class="br"></div>
    </aside>

    {# ── Catégories ── #}
    <aside class="single_sidebar_widget post_category_widget">
      <h4 class="widget_title">Catégories</h4>
      <ul class="list cat-list">
        {% for categorie in categories %}
          <li>
            <a href="{{ path('app_posts_by_categorie', { id: categorie.id }) }}"
               class="categorie-link d-flex justify-content-between{% if app.request.get('id') == categorie.id %} active{% endif %}"
               data-categorie-id="{{ categorie.id }}">
              <p>{{ categorie.name }}</p>
              <p>{{ postsByCategorie[categorie.id] ?? 0 }}</p>
            </a>
          </li>
        {% endfor %}
      </ul>
      <div class="br"></div>
    </aside>

    {# ── Articles récents ── #}
    {% if popularPosts is defined and popularPosts|length > 0 %}
    <aside class="single_sidebar_widget popular_post_widget">
      <h3 class="widget_title">Articles récents</h3>
      {% for popularPost in popularPosts %}
        <div class="media post_item">
          {% if popularPost.imageName %}
            <img src="{{ asset('images/posts/' ~ popularPost.imageName) }}"
                 alt="{{ popularPost.title }}"
                 style="max-width:80px;height:60px;object-fit:cover;border-radius:4px;">
          {% endif %}
          <div class="media-body">
            <a href="{{ path('app_single_posts', { id: popularPost.id }) }}">
              <h3>{{ popularPost.title }}</h3>
            </a>
            <p>{{ popularPost.createdAt|date('d M Y') }}</p>
          </div>
        </div>
      {% endfor %}
      <div class="br"></div>
    </aside>
    {% endif %}

    {# ── CTA devis ── #}
    <aside class="single_sidebar_widget" style="background:#eef6ff;border-radius:10px;padding:24px 20px;text-align:center;">
      <h4 style="color:#1e2d3e;">Un projet digital ?</h4>
      <p class="small mb-3">Parlez-nous de votre besoin — réponse sous 48 h, sans engagement.</p>
      <a class="primary_btn" style="font-size:.85rem;padding:10px 20px;"
         href="{{ path('app_quote', {'_locale': app.request.locale ?? 'fr'}) }}">
        <span>Demander un devis</span>
      </a>
    </aside>

  </div>
</div>
